generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Video {
  id        Int      @id @default(autoincrement())
  title     String
  niche     String?
  keywords  String?
  fileUrl   String
  createdAt DateTime @default(now())
}